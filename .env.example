# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# App queries & Prisma Client — use your primary connection (often pooled in prod).
DATABASE_URL=postgresql://vibeflow:vibeflow@localhost:5433/vibeflow?schema=public
# Migrations & introspection — direct DB URL. Local: same as DATABASE_URL.
# Hosted DBs (e.g. Neon/Supabase): pooled URL in DATABASE_URL, non-pooled in DATABASE_DIRECT_URL.
DATABASE_DIRECT_URL=postgresql://vibeflow:vibeflow@localhost:5433/vibeflow?schema=public

# =============================================================================
# API (apps/api) — copy to apps/api/.env or load from repo root
# =============================================================================
NODE_ENV=development
PORT=4000
# Signs short-lived access JWTs. Refresh sessions are opaque tokens stored hashed in DB (RefreshToken).
JWT_SECRET=change-me-to-a-long-random-string
# Comma-separated origins; localhost and 127.0.0.1 differ for CORS.
WEB_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Trending cache + auth: refresh sessions (`vibeflow:rt:*`) and JWT denylist (`vibeflow:jwt:deny:*`)
REDIS_URL=redis://localhost:6380

# =============================================================================
# Mux — General (dashboard: your environment, e.g. Production)
# =============================================================================
MUX_ENVIRONMENT_ID=
MUX_ENVIRONMENT_KEY=
MUX_ENVIRONMENT_NAME=Production

# =============================================================================
# Mux — Access Tokens (dashboard: Token ID + Secret Key)
# =============================================================================
MUX_ACCESS_TOKEN_ID=
MUX_ACCESS_TOKEN_SECRET=

# =============================================================================
# Mux — Webhooks (Settings → Webhooks) — required for POST /webhooks/mux to verify
# =============================================================================
# Signing secret shown next to your webhook URL (not the same as playback “Signing keys”).
MUX_WEBHOOK_SECRET=

# =============================================================================
# Mux — Signing keys (playback / JWT; optional fallback if MUX_WEBHOOK_SECRET unset)
# =============================================================================
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_SECRET=

# =============================================================================
# Web (apps/web) — public, Vite-exposed
# =============================================================================
VITE_API_URL=http://localhost:4000

# =============================================================================
# ngrok — public URL for Mux → POST /webhooks/mux
# =============================================================================
# Get token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
#
# Docker (tunnel points at the API container, recommended for webhooks):
#   npm run docker:up:ngrok
#   npm run webhook:url
#
# Local npm dev (optional):
#   npm run dev:ngrok   # or: npm run ngrok:api  in another terminal

# =============================================================================
# Docker Compose (`docker compose up --build`)
# =============================================================================
# API receives DATABASE_URL, DATABASE_DIRECT_URL, REDIS_URL, and WEB_ORIGIN from
# compose; keep JWT_SECRET and all MUX_* variables in this file (used via env_file).
# Rebuild the web image if you change the public API URL (VITE_API_URL build arg).
